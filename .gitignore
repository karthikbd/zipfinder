# Workspace-level .gitignore  (package_build mono-repo)

# address-finder is a separate git repo nested here — tracked independently
address-finder/

# Codacy CLI runtime directories (machine-local: binary, logs, tool caches)
.codacy/
zip-finder/.codacy/

# Codacy VS Code AI instructions (machine-local, not committed)
.github/instructions/codacy.instructions.md

# Corporate TLS certificate (sensitive, machine-local)
corp-root.crt

# Large GeoNames raw data files downloaded locally for zip-finder builds
geonames_complete_data/
geonames_processed/

# bd-streetmap-offline is a separate upstream repo checked out here
bd-streetmap-offline/

# Python cache / compiled files
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.eggs/
develop-eggs/

# Root-level virtual environment and lock files
Pipfile
Pipfile.lock
.env
.venv/

# IDE workspace settings (machine-local)
.vscode/settings.json
